[advice]
  useCoreFSMonitorConfig = false

[alias]
  ca = commit --amend --no-edit
  ce = commit --allow-empty --message
  cm = commit --message
  fe = fetch origin
  ig = update-index --assume-unchanged
  lo = log --follow --
  pl = pull --recurse-submodules
  pu = push --follow-tags --recurse-submodules=check --set-upstream origin HEAD
  rb = rebase --rebase-merges
  rs = restore
  sa = stash
  st = status
  sw = switch

[core]
  autocrlf = input
  excludesfile = ~/.config/git/ignore
  attributesFile = ~/.config/git/attributes

[credential]
  helper = store

[diff]
  colorMoved = default

[init]
  defaultBranch = staging

[merge]
  conflictstyle = zdiff3

[pull]
  rebase = true

[push]
  default = current

[submodule]
  recurse = false

[url "git@n0bra1n3r.github.com"]
  insteadOf = git@github.com

